# Copy to .env and fill in.  Never commit the real .env.
# ---------------------------------------------------------------------------

# Your root domain managed in Cloudflare (no scheme, no trailing slash)
DOMAIN=example.com

# Cloudflare Tunnel token.
# Create the tunnel in Cloudflare dashboard:
#   Zero Trust -> Networks -> Tunnels -> Create a tunnel -> "Cloudflared"
# Copy the token from the "install connector" command (the long eyJ... string).
CLOUDFLARE_TUNNEL_TOKEN=eyJh...replace-me...
